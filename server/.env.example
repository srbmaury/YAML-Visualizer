# Environment Variables
NODE_ENV=development
PORT=5000

# Database
# Local MongoDB: mongodb://localhost:27017/yaml-visualizer
# MongoDB Atlas: Get your connection string from https://cloud.mongodb.com/
MONGODB_URI=mongodb://localhost:27017/yaml-visualizer

# JWT Secret
# IMPORTANT: Generate a secure random string for production!
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Origin (Your frontend URL)
# Development: http://localhost:5173
# Production: https://your-domain.com
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# GitHub Integration (Optional)
# API_BASE_URL: Your public server URL (needed for webhooks)
# GITHUB_TOKEN: Personal access token from https://github.com/settings/tokens
#   - Scopes needed: public_repo (or repo for private repos)
#   - Why needed: Increases rate limit from 60 to 5,000 requests/hour
#   - Leave empty if not using GitHub integration
API_BASE_URL=http://localhost:5000
GITHUB_TOKEN=